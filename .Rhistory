# Combine coordinates with attribute(s)
df <- cbind(coords, bri_within[, c("mean.psi", "sd.psi")])
# Convert to stars object
dat.stars_brit <- st_as_stars(df, dims = c("X", "Y"))
# dissolve the shapefile
water_dissolved <- water_sp %>%
mutate(variable=1) %>%
group_by(variable) %>%
summarize(geometry = st_union(geometry), .groups = "drop")
all_reg_preds <- readRDS("Data/Intermediate_data/all_reg_occu.rds")
all_sumary <- all_reg_preds %>%
dplyr::group_by(wcorrid, Subspecies) %>%
dplyr::summarise(mean=mean(mean.psi), sd=mean(sd.psi))
all_sumary
#**************************************************************
#______Fig. 3A
#____ state-wide occupancy variation inside versus outside the FLWC
us_states <- ne_states(country = "United States of America", returnclass = "sf")
FL <- us_states[us_states$name == "Florida", ]
plot(st_geometry(FL))
FL <- st_transform(FL, crs = st_crs(spatial_brit))
pred.sfbrit <- st_as_sf(bri_final)
pred.sfbrit1 <- pred.sfbrit %>%
st_set_crs(4326)
dim(bri_final)
#inside corridor
wcorrid <- st_make_valid(wcorrid)
incorr <- lengths(st_intersects(pred.sfbrit1,wcorrid))>0
incor_occ <- as.data.frame(bri_final[incorr,])
dim(incor_occ)
incor_occ$wcorrid <- "Inside"
#outside corridor
outcorr <- lengths(st_intersects(pred.sfbrit1,wcorrid))==0
outcor_occ <- as.data.frame(bri_final[outcorr,])
dim(outcor_occ)
outcor_occ$wcorrid <- "Outside"
#combine
allpreds <- rbind(incor_occ, outcor_occ)
allpreds$wcorrid <- as.factor(allpreds$wcorrid)
allpreds <- read.csv("Data/Intermediate_data/all_occ_pred.csv", header = TRUE)
preds_sumary <- allpreds %>%
dplyr::group_by(wcorrid) %>%
dplyr::summarise(mean=mean(mean.psi), sd=mean(sd.psi))
preds_sumary
