# Example species list (replace with your own)
species_list <- unique(deluca$scientific_name)
# Create results
obs_df <- lapply(species_list, function(sp) {
osceola  <- get_obs_count(sp, 938)
florida  <- get_obs_count(sp, 21)
global   <- get_obs_count(sp, NA)
data.frame(
species = sp,
osceola = osceola,
florida = florida,
all     = global
)
}) %>%
bind_rows()
