bbox_polygons <- purrr::pmap(
list(final_df_all$sw_lng, final_df_all$sw_lat, final_df_all$ne_lng, final_df_all$ne_lat),
function(xmin, ymin, xmax, ymax) {
st_polygon(list(matrix(
c(
xmin, ymin,
xmax, ymin,
xmax, ymax,
xmin, ymax,
xmin, ymin
),
ncol = 2,
byrow = TRUE
)))
}
)
# Create sf object and assign WGS84 CRS
bbox_sf <- st_sf(
polygon_id = final_df_all$polygon_id,
geometry = st_sfc(bbox_polygons, crs = 4326)
)
# Project to a meter-based CRS (e.g., EPSG:3857)
bbox_sf_m <- st_transform(bbox_sf, crs = 3857)
# Calculate area in square meters
bbox_sf_m$area_m2 <- st_area(bbox_sf_m)
# Join area back to original dataframe
final_df_all_with_area <- final_df_all %>%
left_join(st_drop_geometry(bbox_sf_m), by = "polygon_id") %>%
mutate(area_m2 = as.numeric(area_m2))  # optional: convert from units
final_df_all_with_area
target_area
# Project to a meter-based CRS (e.g., EPSG:3857)
bbox_sf_m <- st_transform(bbox_sf, crs = 32617)
# Calculate area in square meters
bbox_sf_m$area_m2 <- st_area(bbox_sf_m)
# Join area back to original dataframe
final_df_all_with_area <- final_df_all %>%
