target_area
# Create bbox as points first (lat/lon)
bbox_points <- st_as_sf(data.frame(
x = c(final_df_all$sw_lng, final_df_all$ne_lng),
y = c(final_df_all$sw_lat, final_df_all$ne_lat)
), coords = c("x", "y"), crs = 4326)
# Project bbox points to UTM
bbox_points_utm <- st_transform(bbox_points, 32617)
# Rebuild bbox polygons from UTM coords (using min/max of projected points)
bbox_polygons_utm <- purrr::pmap(
list(final_df_all$sw_lng, final_df_all$sw_lat, final_df_all$ne_lng, final_df_all$ne_lat),
function(sw_lng, sw_lat, ne_lng, ne_lat) {
# Project bbox corners to UTM first
pts_wgs <- st_sfc(
st_point(c(sw_lng, sw_lat)),
st_point(c(ne_lng, sw_lat)),
st_point(c(ne_lng, ne_lat)),
st_point(c(sw_lng, ne_lat)),
crs = 4326
)
pts_utm <- st_transform(pts_wgs, 32617)
coords <- st_coordinates(pts_utm)[,1:2]
st_polygon(list(rbind(coords, coords[1,])))
}
)
bbox_sf_utm <- st_sf(
polygon_id = final_df_all$polygon_id,
geometry = st_sfc(bbox_polygons_utm, crs = 32617)
)
# Calculate areas
bbox_sf_utm$area_m2 <- st_area(bbox_sf_utm)
# Join back to dataframe
final_df_all_with_area <- final_df_all %>%
left_join(st_drop_geometry(bbox_sf_utm), by = "polygon_id") %>%
mutate(area_m2 = as.numeric(area_m2))
final_df_all_with_area
